diff --git a/src/NzbDrone.Core/Download/Clients/QBittorrent/QBittorrent.cs b/src/NzbDrone.Core/Download/Clients/QBittorrent/QBittorrent.cs
index e8917a0c977..ca2b6510f76 100644
--- a/src/NzbDrone.Core/Download/Clients/QBittorrent/QBittorrent.cs
+++ b/src/NzbDrone.Core/Download/Clients/QBittorrent/QBittorrent.cs
@@ -611,10 +611,14 @@ private ValidationFailure TestGetTorrents()

         protected bool HasReachedSeedLimit(QBittorrentTorrent torrent, QBittorrentPreferences config)
         {
+            _logger.Debug("HasReachedSeedLimit torrent.Ratio: '{0}'", torrent.Ratio);
+            _logger.Debug("HasReachedSeedLimit torrent.RatioLimit: '{0}'", torrent.RatioLimit);
+
             if (torrent.RatioLimit >= 0)
             {
                 if (torrent.Ratio >= torrent.RatioLimit)
                 {
+                    _logger.Debug("HasReachedSeedLimit: BY TORRENT RATIO LIMIT");
                     return true;
                 }
             }
@@ -622,12 +626,14 @@ protected bool HasReachedSeedLimit(QBittorrentTorrent torrent, QBittorrentPrefer
             {
                 if (Math.Round(torrent.Ratio, 2) >= config.MaxRatio)
                 {
+                    _logger.Debug("HasReachedSeedLimit: BY MAX RATIO LIMIT");
                     return true;
                 }
             }

             if (HasReachedSeedingTimeLimit(torrent, config))
             {
+                _logger.Debug("HasReachedSeedLimit: BY SEEDING TIME LIMIT");
                 return true;
             }

